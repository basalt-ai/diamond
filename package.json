{
  "name": "diamond",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "concurrently -n next,worker,pgboss -c blue,green,magenta \"next dev\" \"node --env-file=.env.local --import=tsx scripts/worker.ts\" \"PORT=3001 node --env-file=.env.local node_modules/@pg-boss/dashboard/bin/cli.js\"",
    "dev:next": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "ultracite check",
    "lint:fix": "ultracite fix",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:seed": "node --env-file=.env.local --import=tsx src/db/seeds/index.ts",
    "db:studio": "drizzle-kit studio",
    "check": "ultracite check",
    "fix": "ultracite fix",
    "worker:dev": "node --env-file=.env.local --import=tsx --watch scripts/worker.ts",
    "worker:start": "node dist/worker/scripts/worker.js"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "3.993.0",
    "@aws-sdk/s3-request-presigner": "3.993.0",
    "@base-ui/react": "1.2.0",
