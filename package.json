    "@supabase/supabase-js": "2.97.0",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "drizzle-orm": "0.45.1",
    "duckdb-async": "1.4.2",
    "geist": "1.7.0",
    "lucide-react": "0.575.0",
    "next": "16.1.6",
    "next-themes": "0.4.6",
    "openai": "6.22.0",
    "p-limit": "7.3.0",
    "p-retry": "7.1.1",
    "pg": "8.18.0",
    "pg-boss": "12.13.0",
    "postgres": "3.4.8",
    "radix-ui": "1.4.3",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "recharts": "2.15.4",
    "shadcn": "3.8.5",
    "sonner": "2.0.7",
    "tailwind-merge": "3.5.0",
    "tw-animate-css": "1.4.0",
    "uuidv7": "1.1.0",
